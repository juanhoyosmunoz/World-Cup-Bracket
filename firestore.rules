rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- helpers -------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function authEmail()  { return request.auth.token.email; }
    function isAntenna()  { return isSignedIn() && authEmail().lower().matches('.*@antenna[.]live'); }
    function isAdmin()    { return isSignedIn() && (request.auth.token.admin == true); }
    function isSelf(uid)  { return isSignedIn() && request.auth.uid == uid; }

    // The single appConfig doc gates global lock times and tournament status.
    function appConfig()  { return get(/databases/$(database)/documents/appConfig/main).data; }

    // Per-fixture lock: 10 min before kickoff, or once the result is final.
    // For Firestore rules we trust a server-set `lockAt` timestamp on the fixture.
    function fixtureLocked(fixtureId) {
      let f = get(/databases/$(database)/documents/fixtures/$(fixtureId)).data;
      return request.time >= f.lockAt || f.status == 'FINISHED' || f.status == 'LIVE';
    }

    // Knockout bracket lock: shared cutoff stored on appConfig.
    function knockoutLocked() {
      let cfg = appConfig();
      return request.time >= cfg.knockoutLockAt;
    }

    // Favorite team lock: shared cutoff (first KO match minus 10 min, or admin override).
    function favoriteLocked() {
      let cfg = appConfig();
      return request.time >= cfg.favoriteLockAt;
    }

    // --- users ---------------------------------------------------------------
    match /users/{uid} {
      // Profile readable by any signed-in @antenna.live user (for leaderboard display).
      allow read: if isAntenna();
      // Profile is created/updated by the user themselves on first login.
      // displayName/photoURL/email are user-controlled; `admin` flag is NEVER writable
      // from the client — it lives in a custom claim, set by an admin-only callable fn.
      allow create: if isAntenna() && isSelf(uid)
        && request.resource.data.email == authEmail()
        && !('admin' in request.resource.data);
      allow update: if isAntenna() && isSelf(uid)
        && request.resource.data.email == resource.data.email
        && !('admin' in request.resource.data.diff(resource.data).affectedKeys());
      // Admins can patch any user (e.g., for backfills/corrections).
      allow update, delete: if isAdmin();
    }

    // Favorite team selection — single doc per user, locked at tournament start.
    match /favorites/{uid} {
      allow read: if isAntenna();
      allow create, update: if isAntenna() && isSelf(uid) && !favoriteLocked();
      allow write: if isAdmin();
    }

    // --- teams (read-only for users) ----------------------------------------
    match /teams/{teamId} {
      allow read: if isAntenna();
      allow write: if isAdmin();
    }

    // --- fixtures (read-only for users) -------------------------------------
    match /fixtures/{fixtureId} {
      allow read: if isAntenna();
      allow write: if isAdmin();
    }

    // --- results (read-only for users; admins + functions write) ------------
    match /results/{fixtureId} {
      allow read: if isAntenna();
      allow write: if isAdmin();
    }

    // --- group-stage predictions --------------------------------------------
    // Document ID format: `${uid}_${fixtureId}` so each user has at most one
    // prediction per fixture (deterministic doc ID makes rules and reads easier).
    match /predictions/{predictionId} {
      // Visible to self any time. Visible to other antenna users ONLY after lock.
      allow read: if isAntenna() && (
        isSelf(resource.data.uid) ||
        isAdmin() ||
        fixtureLocked(resource.data.fixtureId)
      );

      // Create only with matching ID, own uid, before fixture lock.
      allow create: if isAntenna()
        && isSelf(request.resource.data.uid)
        && predictionId == request.resource.data.uid + '_' + request.resource.data.fixtureId
        && !fixtureLocked(request.resource.data.fixtureId);

      // Update only own prediction, before lock, and uid/fixtureId immutable.
      allow update: if isAntenna()
        && isSelf(resource.data.uid)
        && !fixtureLocked(resource.data.fixtureId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.fixtureId == resource.data.fixtureId;

      allow delete: if isAdmin();
    }

    // --- knockout bracket (one doc per user) --------------------------------
    match /knockoutBrackets/{uid} {
      // Visible to self any time; visible to all antenna users after the
      // global knockout lock.
      allow read: if isAntenna() && (isSelf(uid) || isAdmin() || knockoutLocked());
      allow create, update: if isAntenna() && isSelf(uid) && !knockoutLocked();
      allow delete: if isAdmin();
    }

    // --- leaderboard (read-only; written by recompute function or admin) ----
    match /leaderboard/{uid} {
      allow read: if isAntenna();
      allow write: if isAdmin();
    }

    // --- appConfig + adminConfig (admin-managed) ----------------------------
    match /appConfig/{doc} {
      allow read: if isAntenna();
      allow write: if isAdmin();
    }
    match /adminConfig/{doc} {
      allow read, write: if isAdmin();
    }

    // --- syncHealth (admin-readable; written by functions/admin) ------------
    match /syncHealth/{doc} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
