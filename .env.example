# Firebase web app config (from Firebase console → Project settings → Web app)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Only allow Google sign-in from this domain
VITE_ALLOWED_EMAIL_DOMAIN=antenna.live

# Admin email allow-list (comma separated, lowercased)
# These three users will be granted the `admin` custom claim by the setAdmins fn.
VITE_ADMIN_EMAILS=lauren@antenna.live,camila@antenna.live,juan@antenna.live

# Optional: connect to local Firebase emulators when running `npm run dev`
VITE_USE_EMULATORS=false

# Optional: run the app with an in-memory mock backend (no Firebase required)
# Set to "true" to preview the UI locally without any setup.
VITE_DEMO_MODE=false

# --- functions / server-side ------------------------------------------------
# API-FOOTBALL key (https://www.api-football.com/)
# Set with: firebase functions:config:set apifootball.key="YOUR_KEY"
# or as a secret: firebase functions:secrets:set APIFOOTBALL_KEY
APIFOOTBALL_KEY=

# FIFA World Cup 2026 league id in API-FOOTBALL (verify in their dashboard)
APIFOOTBALL_LEAGUE_ID=1
APIFOOTBALL_SEASON=2026
