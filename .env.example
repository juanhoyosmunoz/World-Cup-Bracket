# --- Frontend (Vite) ---------------------------------------------------------

# Backend API base URL
VITE_API_BASE_URL=http://localhost:8000

# Only allow sign-in from this domain
VITE_ALLOWED_EMAIL_DOMAIN=antenna.live

# Admin email allow-list (comma separated, lowercased)
VITE_ADMIN_EMAILS=lauren@antenna.live,camila@antenna.live,juan@antenna.live

# Optional: run the app with an in-memory mock backend (no API required)
# Set to "true" to preview the UI locally without any setup.
VITE_DEMO_MODE=false

# --- Backend (see backend/.env.example for full backend config) -----------
