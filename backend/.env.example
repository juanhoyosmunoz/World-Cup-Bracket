# PostgreSQL connection string
DATABASE_URL=postgresql://localhost:5432/worldcup

# Auth proxy header names (set by your reverse proxy / API gateway)
AUTH_HEADER_USER_ID=X-Auth-User-Id
AUTH_HEADER_EMAIL=X-Auth-User-Email
AUTH_HEADER_NAME=X-Auth-User-Name
AUTH_HEADER_PHOTO=X-Auth-User-Photo

# For local dev without a proxy: simulate a logged-in user
DEV_USER_EMAIL=juan@antenna.live
DEV_USER_NAME=Juan Hoyos

# Comma-separated admin emails
ADMIN_EMAILS=lauren@antenna.live,camila@antenna.live,juan@antenna.live

# Domain whitelist
ALLOWED_EMAIL_DOMAIN=antenna.live

# API-FOOTBALL credentials
APIFOOTBALL_KEY=
APIFOOTBALL_LEAGUE_ID=1
APIFOOTBALL_SEASON=2026

# Lock lead time (minutes before kickoff that predictions lock)
LOCK_LEAD_MINUTES=60

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173
